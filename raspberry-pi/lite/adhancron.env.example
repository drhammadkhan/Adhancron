# Native Raspberry Pi OS Lite defaults.
ADHAN_PLAYBACK_METHOD=attached
ADHAN_ATTACHED_AUDIO_ENABLED=true
ADHAN_ALSA_DEVICE=default
ADHAN_DISPLAY_ADDRESS=adhanclock.local
PUBLIC_BASE_URL=http://adhanclock.local
ADHAN_VOLUME=0.8
TZ=Europe/London

# These can remain blank and be configured later in the dashboard.
ADHAN_LATITUDE=
ADHAN_LONGITUDE=
GOOGLE_CAST_HOST=
GOOGLE_CAST_PORT=8009
AIRPLAY_IDENTIFIER=
DLNA_LOCATION=
HA_TOKEN=
HA_URL=http://homeassistant.local:8123
HA_ENTITY_ID=media_player.bedroom_speaker
