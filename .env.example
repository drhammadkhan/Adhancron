# Copy this to .env for local Docker Compose runs.
HA_URL=http://homeassistant.local:8123
HA_ENTITY_ID=media_player.bedroom_speaker
PUBLIC_BASE_URL=http://YOUR_DOCKER_HOST_IP:8090
ADHAN_VOLUME=0.8
ADHAN_USE_ANNOUNCE=true
ADHAN_PLAY_ATTEMPTS=2
ADHAN_PLAYBACK_TIMEOUT=15
ADHAN_PLAYBACK_POLL_INTERVAL=1
ADHAN_MEDIA_CONTENT_TYPE=audio/mpeg
TZ=Europe/London

# Optional. You can also save this from the web UI after startup.
HA_TOKEN=
